# URL completa do banco (local). No Railway o app também aceita MYSQL_URL / MYSQL_PUBLIC_URL
# ou variáveis MYSQLHOST, MYSQLUSER, MYSQLPASSWORD, MYSQLPORT, MYSQLDATABASE do plugin MySQL.
DATABASE_URL=mysql://root:SENHA@host:PORTA/railway

# Identificação das provas no MySQL (coluna provas.titulo).
# Se você IMPORTOU um dump idêntico ao da segunda-prova-padm-ii, os títulos no banco
# costumam ser "Segunda Prova …" — nesse caso use:
#   PROVA_TITULO_LIKE=Segunda Prova
# Se você rodou database/clonar_provas_estatistica_computacional.sql, use o padrão EC abaixo.
# PROVA_TITULO_LIKE pode ser substring (vira %substring%) ou padrão LIKE completo com %
PROVA_TITULO_LIKE=Estatística Computacional - Segunda Avaliação
PROVA_TITULO_EXIBICAO=Estatística Computacional — Segunda Avaliação

# Porta local (Railway usa a variável PORT automaticamente)
PORT=3001

# Senha do painel administrativo (/admin)
ADMIN_PASSWORD=troque-por-uma-senha-forte

# Limite de tentativas de login no admin
ADMIN_LOGIN_MAX_TENTATIVAS=5
ADMIN_LOGIN_BLOQUEIO_MINUTOS=10

# Geolocalização (campus UFCA Juazeiro — IP via ip-api.com + GPS opcional no navegador)
# GEO_MODO: registrar = só grava; bloquear_gps_fora = recusa início se GPS indicar fora da cerca
GEO_MODO=registrar
CAMPUS_LAT=-7.21376
CAMPUS_LON=-39.31538
CAMPUS_RAIO_METROS=700
